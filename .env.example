# WatchParty Environment Variables
# Copy this file to .env and fill in your values

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Fast2SMS API Key (get from https://www.fast2sms.com)
FAST2SMS_API_KEY="your-fast2sms-api-key"

# Admin Credentials
ADMIN_EMAIL="admin@watchparty.com"
ADMIN_PASS="your-secure-admin-password"
# For production, use hashed password instead:
# ADMIN_PASS_HASH="pbkdf2:sha256:..."

# Flask Secret Key (auto-generated if not set)
# SECRET_KEY="your-random-secret-key"
